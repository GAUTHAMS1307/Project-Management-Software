# Database (PostgreSQL connection string – required for both local dev and Render)
DATABASE_URL=

# Secret used to sign JWT tokens (generate a strong random value for production)
JWT_SECRET=

# SendGrid credentials for email notifications (optional)
SENDGRID_API_KEY=
VERIFIED_SENDER_EMAIL=

# Base URL of the application (used in email links)
APP_BASE_URL=

# ---- Render (backend) only ----
# Comma-separated list of allowed frontend origins for CORS.
# Set this to your Vercel frontend URL, e.g.:
#   CORS_ORIGIN=https://my-project.vercel.app
CORS_ORIGIN=

# ---- Vercel (frontend) only ----
# URL of the Render backend API.  Set in the Vercel project settings as an
# environment variable, e.g.:
#   VITE_API_URL=https://project-management-api.onrender.com
VITE_API_URL=
